# ──────────────────────────────────────────────────────────────
# AutoApply AI — n8n Cloud Deployment Environment Variables
#
# Copy this file to .env and fill in all required values.
# Variables marked REQUIRED must be set before deploying.
# ──────────────────────────────────────────────────────────────

# ─── n8n Core ─────────────────────────────────────────────────
N8N_BASIC_AUTH_USER=admin                               # REQUIRED
N8N_BASIC_AUTH_PASSWORD=                                # REQUIRED — generate a strong password
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=https
N8N_WEBHOOK_URL=https://your-n8n-domain.onrender.com   # REQUIRED — your public n8n URL
GENERIC_TIMEZONE=Europe/Paris

# ─── Database (Supabase PostgreSQL) ──────────────────────────
# Get these from Supabase Dashboard → Settings → Database
DB_POSTGRESDB_HOST=db.xxxxxxxxxxxx.supabase.co          # REQUIRED
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=postgres                         # REQUIRED
DB_POSTGRESDB_USER=postgres                             # REQUIRED
DB_POSTGRESDB_PASSWORD=                                 # REQUIRED
APP_DATABASE_URL=postgresql://postgres:PASSWORD@db.xxxxxxxxxxxx.supabase.co:5432/postgres?schema=public  # REQUIRED

# ─── LLM API Keys ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...                            # REQUIRED — used for scoring and tailoring
OPENAI_API_KEY=sk-...                                   # Optional — fallback LLM

# ─── Job Board API Keys ──────────────────────────────────────
ADZUNA_APP_ID=                                          # REQUIRED — https://developer.adzuna.com
ADZUNA_APP_KEY=                                         # REQUIRED
JSEARCH_API_KEY=                                        # Optional — RapidAPI JSearch
JOOBLE_API_KEY=                                         # Optional — https://jooble.org/api/about
REED_API_KEY=                                           # Optional — https://www.reed.co.uk/developers

# ─── App Integration ─────────────────────────────────────────
N8N_WEBHOOK_SECRET=                                     # REQUIRED — must match web app's N8N_WEBHOOK_SECRET
APP_URL=https://autoapply.works                         # REQUIRED — web app URL for webhook callbacks

# ─── Storage ─────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co           # REQUIRED — for file storage
SUPABASE_SERVICE_KEY=eyJ...                             # REQUIRED — Supabase service role key
