# ──────────────────────────────────────────────────────────────
# AutoApply AI — n8n Cloud Deployment Environment Variables
#
# Copy this file to .env and fill in all required values.
# Variables marked REQUIRED must be set before deploying.
# ──────────────────────────────────────────────────────────────

# ─── n8n Core ─────────────────────────────────────────────────
N8N_BASIC_AUTH_USER=admin                               # REQUIRED
N8N_BASIC_AUTH_PASSWORD=                                # REQUIRED — generate a strong password
N8N_HOST=0.0.0.0
N8N_PORT=5678
N8N_PROTOCOL=https
N8N_WEBHOOK_URL=https://autoapply-n8n.onrender.com     # REQUIRED — your public n8n URL
GENERIC_TIMEZONE=Europe/Paris

# ─── n8n Internal Database (Neon PostgreSQL) ───────────────────
# n8n uses this for its own workflow/execution storage.
# Uses a separate "n8n" schema to avoid conflicts with app tables.
# Get connection details from Neon Console → Connection Details
DB_POSTGRESDB_HOST=ep-morning-meadow-ag8qe5hq-pooler.c-2.eu-central-1.aws.neon.tech  # REQUIRED
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=neondb                           # REQUIRED
DB_POSTGRESDB_USER=                                     # REQUIRED — Neon username
DB_POSTGRESDB_PASSWORD=                                 # REQUIRED — Neon password

# ─── App Database URL (for workflow Postgres queries) ──────────
# Used by the job discovery pipeline to query active users.
# Same Neon database, but full connection string for n8n Postgres nodes.
APP_DATABASE_URL=postgresql://USER:PASSWORD@ep-morning-meadow-ag8qe5hq-pooler.c-2.eu-central-1.aws.neon.tech/neondb?sslmode=require  # REQUIRED

# ─── LLM API Keys ────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...                            # REQUIRED — used for scoring and tailoring

# ─── Job Board API Keys ──────────────────────────────────────
ADZUNA_APP_ID=e2af75b6                                  # Already configured
ADZUNA_APP_KEY=                                         # REQUIRED
JSEARCH_API_KEY=                                        # Optional — RapidAPI JSearch
JOOBLE_API_KEY=                                         # Optional — https://jooble.org/api/about
REED_API_KEY=                                           # Optional — https://www.reed.co.uk/developers

# ─── App Integration ─────────────────────────────────────────
N8N_WEBHOOK_SECRET=                                     # REQUIRED — must match web app's N8N_WEBHOOK_SECRET
APP_URL=https://autoapply.works                         # REQUIRED — web app URL for webhook callbacks

# ─── PDF Generation ──────────────────────────────────────────
GOTENBERG_URL=https://autoapply-gotenberg.onrender.com  # Render Gotenberg service URL
